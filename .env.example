# SkyPlatform — Environment Variables
# Copy to .env and edit for your environment

# Server
NODE_ENV=development
PORT=3000

# Database (optional — in-memory fallback used if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/skyplatform

# JWT Secrets (change in production!)
JWT_SECRET=skyplatform-super-secret-dev-key-2026
REFRESH_SECRET=skyplatform-refresh-secret-2026

# Demo mode (random ops events every 2 min)
DEMO_MODE=true

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (optional for real notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
